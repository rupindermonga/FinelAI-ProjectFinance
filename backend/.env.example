# Copy this file to .env and fill in your values

# Gemini API Keys — comma-separated, tried in order (key1 first, key2 if key1 is rate-limited, etc.)
# Get free keys from: https://aistudio.google.com/app/apikey  (one per Google account)
GEMINI_API_KEYS=your_key_1_here,your_key_2_here,your_key_3_here

# Gemini model to use
GEMINI_MODEL=gemini-2.5-flash

# JWT Secret (change this to a random string in production)
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=sqlite:///./invoices.db

# Upload folder
UPLOAD_FOLDER=./uploads

# CORS — comma-separated list of allowed origins (no wildcards in production)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Admin bootstrap credentials (used by create_admin.py)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@hm.local
